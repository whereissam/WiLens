---
import MainLayout from "../layouts/MainLayout.astro";

const githubHref = "https://github.com/whereissam/WiLens";
const downloadHref = `${githubHref}/releases/latest/download/WiLens.dmg`;

const featureCards = [
  {
    title: "Scans Wi-Fi QR codes",
    text: "Point your Mac camera at a printed code, shared screen, router label, or onboarding poster.",
  },
  {
    title: "Shows the network first",
    text: "Review the SSID, security type, and hidden password state before joining anything.",
  },
  {
    title: "Keeps details local",
    text: "The scan, decode, and join flow happens on your Mac. Nothing is uploaded to a server.",
  },
  {
    title: "Built for macOS",
    text: "A focused desktop utility with a small footprint and a direct path from camera to connection.",
  },
];
---

<MainLayout
  title="WiLens | Wi-Fi QR scanner for macOS"
  description="WiLens scans Wi-Fi QR codes on macOS, previews the network, and joins in seconds without cloud upload."
>
  <main class="site-shell" id="top">
    <nav class="navbar" aria-label="Primary navigation">
      <a class="brand" href="#top" aria-label="WiLens home">
        <img src="/app-icon.png" alt="" />
        <span>WiLens</span>
      </a>

      <div class="nav-links">
        <a href="#workflow">Workflow</a>
        <a href="#features">Features</a>
        <a href={githubHref}>GitHub</a>
        <a href="#download">Download</a>
        <button
          class="theme-toggle"
          type="button"
          data-theme-toggle
          aria-pressed="false"
          aria-label="Switch theme"
          title="Toggle theme"
        >
          <svg data-theme-icon class="theme-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M20 15.2A8.2 8.2 0 0 1 8.8 4a8.7 8.7 0 1 0 11.2 11.2Z"
              fill="currentColor"
            />
          </svg>
        </button>
      </div>
    </nav>

    <section class="hero" aria-labelledby="hero-title">
      <div class="hero-copy">
        <!-- <div class="hero-mark" aria-hidden="true">
          <img src="/app-icon.png" alt="" />
        </div> -->
        <p class="eyebrow">macOS Wi-Fi QR scanner</p>
        <h1 id="hero-title">Join the network in the room.</h1>
        <p class="hero-text">
          WiLens turns the Wi-Fi QR codes people already share into a one-scan
          connection flow for your Mac.
        </p>

        <div class="hero-actions">
          <a class="button button-primary" href={downloadHref}>Download for macOS</a>
          <a class="button button-secondary" href={githubHref}>View source</a>
        </div>

        <div class="hero-facts" aria-label="Product highlights">
          <span>No cloud upload</span>
          <span>Apple Silicon</span>
          <span>Open source</span>
        </div>
      </div>

      <div class="hero-visual">
        <div class="screenshot-stage">
          <img src="/screenshot.png" alt="WiLens macOS app scanning a Wi-Fi QR code" />
        </div>
        <div class="floating-card floating-card-top" aria-hidden="true">
          <span class="status-dot"></span>
          QR detected
        </div>
        <div class="floating-card floating-card-bottom" aria-hidden="true">
          <strong>Cafe_WiFi</strong>
          <span>Ready to join</span>
        </div>
      </div>
    </section>

    <section class="workflow" id="workflow" aria-labelledby="workflow-title">
      <div class="section-intro">
        <p class="eyebrow">Workflow</p>
        <h2 id="workflow-title">A short path from camera to Wi-Fi.</h2>
      </div>

      <div class="workflow-grid">
        <article>
          <span>01</span>
          <h3>Point</h3>
          <p>Open WiLens and aim at any standard Wi-Fi QR code.</p>
        </article>
        <article>
          <span>02</span>
          <h3>Confirm</h3>
          <p>Check the detected network before your Mac joins it.</p>
        </article>
        <article>
          <span>03</span>
          <h3>Connect</h3>
          <p>Join without typing a long password by hand.</p>
        </article>
      </div>
    </section>

    <section class="product-band" aria-label="Product screenshot">
      <div>
        <p class="eyebrow">Native utility</p>
        <h2>Made for the moments when Wi-Fi is shared out loud, on paper, or on a wall.</h2>
      </div>
      <img src="/app-icon.png" alt="" aria-hidden="true" />
    </section>

    <section class="features" id="features" aria-labelledby="features-title">
      <div class="section-intro">
        <p class="eyebrow">Features</p>
        <h2 id="features-title">Small surface, practical defaults.</h2>
      </div>

      <div class="feature-grid">
        {featureCards.map((feature) => (
          <article class="feature-card">
            <h3>{feature.title}</h3>
            <p>{feature.text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="privacy-panel">
      <div>
        <p class="eyebrow">Privacy</p>
        <h2>Camera in. Wi-Fi out. No account in the middle.</h2>
      </div>
      <p>
        WiLens is local-first and open source, so the QR contents stay on your
        device. macOS may ask for camera and Wi-Fi related permissions because
        the app scans codes and joins networks.
      </p>
    </section>

    <section class="download" id="download" aria-labelledby="download-title">
      <img src="/app-icon.png" alt="" aria-hidden="true" />
      <p class="eyebrow">Download</p>
      <h2 id="download-title">Bring QR Wi-Fi joining to your Mac.</h2>
      <div class="hero-actions">
        <a class="button button-primary" href={downloadHref}>Download for macOS</a>
        <a class="button button-secondary" href={githubHref}>GitHub</a>
      </div>
    </section>

    <footer class="footer">
      <p>WiLens</p>
      <div class="footer-links">
        <a href="#workflow">Workflow</a>
        <a href="#features">Features</a>
        <a href="#download">Download</a>
      </div>
    </footer>
  </main>
</MainLayout>
