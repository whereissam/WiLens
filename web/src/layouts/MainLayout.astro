---
interface Props {
  title?: string;
  description?: string;
}

import "../styles/global.css";

const {
  title = "WiLens",
  description = "Scan a Wi-Fi QR code and join the network from your Mac.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Instrument+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/app-logo.svg" type="image/svg+xml" />
    <script is:inline>
      const storageKey = "wilens-theme";
      const root = document.documentElement;
      const systemTheme = window.matchMedia("(prefers-color-scheme: light)").matches
        ? "light"
        : "dark";
      const savedTheme = localStorage.getItem(storageKey);
      root.dataset.theme = savedTheme || systemTheme;
    </script>
  </head>
  <body>
    <slot />
    <script is:inline>
      const storageKey = "wilens-theme";
      const root = document.documentElement;
      const syncThemeToggle = () => {
        document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
          const isLight = root.dataset.theme === "light";
          button.setAttribute("aria-pressed", String(isLight));
          button.setAttribute("aria-label", isLight ? "Switch to dark mode" : "Switch to light mode");
          const icon = button.querySelector("[data-theme-icon]");
          if (icon) {
            icon.innerHTML = isLight
              ? '<path d="M20 15.2A8.2 8.2 0 0 1 8.8 4a8.7 8.7 0 1 0 11.2 11.2Z" fill="currentColor"></path>'
              : '<circle cx="12" cy="12" r="4.2" fill="currentColor"></circle><path d="M12 2.5v2.4M12 19.1v2.4M21.5 12h-2.4M4.9 12H2.5M18.7 5.3l-1.7 1.7M7 17l-1.7 1.7M18.7 18.7 17 17M7 7 5.3 5.3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>';
          }
        });
      };

      syncThemeToggle();

      document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
        button.addEventListener("click", () => {
          root.dataset.theme = root.dataset.theme === "light" ? "dark" : "light";
          localStorage.setItem(storageKey, root.dataset.theme);
          syncThemeToggle();
        });
      });
    </script>
  </body>
</html>
